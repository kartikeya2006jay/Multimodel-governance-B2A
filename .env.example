# ─────────────────────────────────────────────────────────────────
# Multi-Agent B2A Middleware OS  —  Environment Configuration
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────
APP_NAME=B2A Middleware OS
APP_ENV=development          # development | staging | production
APP_PORT=8000
APP_DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-at-least-64-characters
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Database ─────────────────────────────────────────────────────
# SQLite (dev):  sqlite+aiosqlite:///./b2a.db
# Postgres (prod): postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./b2a.db

# ── JWT / Auth ───────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440       # 24 hours

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.3

# ── Billing Defaults ────────────────────────────────────────────
DEFAULT_AGENT_COST_PER_CALL=0.01     # USD per agent invocation
DEFAULT_LLM_COST_PER_1K_TOKENS=0.002 # USD per 1K tokens (gpt-4o-mini)
DEFAULT_WORKFLOW_BASE_COST=0.05       # USD per workflow trigger

# ── Observability ────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090
LOG_LEVEL=INFO

# ── Multi-Tenancy ────────────────────────────────────────────────
DEFAULT_TENANT_ID=default
MAX_AGENTS_PER_TENANT=50
MAX_WORKFLOWS_PER_TENANT=1000

# ── Security ────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
API_RATE_LIMIT=100             # requests/minute per tenant
